{
  "name": "soprema-substitution-tool",
  "version": "1.0.0",
  "description": "Soprema product substitution request tool",
  "main": "src/main/main.js",
  "scripts": {
    "start": "electron .",
    "build": "electron-builder --mac",
    "publish": "node publish.js"
  },
  "build": {
    "appId": "com.soprema.substitution-tool",
    "productName": "Soprema Substitution Tool",
    "icon": "assets/icon",
    "directories": {
      "output": "dist"
    },
    "files": [
      "src/**/*",
      "assets/**/*",
      "config.json",
      "package.json"
    ],
    "extraResources": [
      {
        "from": "config.json",
        "to": "config.json"
      }
    ],
    "mac": {
      "target": "dmg",
      "icon": "assets/icon.icns",
      "category": "public.app-category.business"
    },
    "win": {
      "target": "nsis"
    },
    "publish": {
      "provider": "github",
      "owner": "revampedplant756",
      "repo": "substitution-request-tool"
    }
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.39.0",
    "@aws-sdk/client-s3": "^3.700.0",
    "electron-updater": "^6.8.3",
    "pdf-parse": "^1.1.1"
  },
  "devDependencies": {
    "dotenv": "^17.3.1",
    "electron": "^33.0.0",
    "electron-builder": "^25.0.0"
  }
}
